source "https://rubygems.org"

# Use the github-pages gem to pin all dependencies (Jekyll, Sass, plugins) to
# exactly the versions GitHub Pages uses, so local and production stay in sync.
# To see current versions: https://pages.github.com/versions/
# To upgrade: run `bundle update github-pages`.
gem "github-pages", group: :jekyll_plugins

# webrick is required for `jekyll serve` on Ruby 3.x (removed from stdlib in 3.0).
gem "webrick"
