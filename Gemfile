source "https://rubygems.org"

# This file controls which versions of Jekyll and its plugins are used.
# After changing it, run `bundle install` to install the new versions,
# or `bundle update` to upgrade to the latest versions allowed by the
# version constraints (~> means "same major/minor, latest patch").
# Always run Jekyll via `bundle exec jekyll serve` so it uses these versions.

gem "jekyll", "~> 4.3"

# The default theme. 2.5 is the latest stable release on RubyGems.
gem "minima", "~> 2.5"

group :jekyll_plugins do
  gem "jekyll-feed", "~> 0.17"
end

# The sections below for Windows/JRuby platforms have been removed —
# they were only needed on Windows and don't apply to macOS.
